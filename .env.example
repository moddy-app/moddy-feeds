# ─── moddy-feeds — variables d'environnement ───────────────────────────────
# Copier en `.env` pour le développement local (jamais commité).

# PostgreSQL DÉDIÉE au service (targets + state interne).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moddy_feeds

# Redis PARTAGÉ avec le bot (feeds:commands, feeds:replies, notifications:queue).
REDIS_URL=redis://localhost:6379/0

# YouTube : uniquement la résolution @handle → channel_id (1 unité de quota/abonnement).
# Optionnel : sans clé, fallback scraping HTML (gratuit mais fragile).
YOUTUBE_API_KEY=

# Twitch : app créée sur dev.twitch.tv/console (client credentials).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── Réglages optionnels (valeurs par défaut sûres) ────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json          # console | json (auto: console en TTY, json sinon/Railway)
# SCHEDULER_TICK_SECONDS=10
# HEARTBEAT_SECONDS=30
# BLUESKY_ENABLED=true
# INSTAGRAM_ENABLED=false
